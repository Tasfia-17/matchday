# MatchDay Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/matchday?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -hex 32"
NEXTAUTH_URL="http://localhost:3000"

# Socket server
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
# SOCKET_SERVER_INTERNAL_URL="http://localhost:4000"
# ADMIN_API_KEY="shared-admin-bridge-secret"

# Sports Data APIs
# TheSportsDB (free tier: https://www.thesportsdb.com/api.php)
THESPORTSDB_API_KEY="1"  # "1" is the free test key
# API-Football (optional, paid: https://www.api-football.com)
# API_FOOTBALL_KEY="your-api-football-key"

# Google Gemini AI (sports analyst chatbot)
GEMINI_API_KEY="your-gemini-api-key"

# Qdrant vector DB (highlight/clip search)
# https://cloud.qdrant.io — free tier available
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""

# Email (Resend)
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="MatchDay <noreply@yourdomain.com>"

# Optional: Redis
REDIS_URL="redis://localhost:6379"

# Optional: CORS
# CORS_ORIGIN="https://yourdomain.com"

# Optional: Logging
# LOG_LEVEL="debug"

# Optional: Skip email verification (development only)
# SKIP_EMAIL_VERIFICATION="true"
